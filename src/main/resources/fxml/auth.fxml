<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.twp.controller.AuthController" style="-fx-background-color: #0A0A0C;">
    <!-- Left Banner -->
    <StackPane fx:id="leftPane" HBox.hgrow="ALWAYS" prefWidth="600" style="-fx-background-color: #050505;">
        <ImageView fx:id="bannerImage" preserveRatio="false" />
        <VBox alignment="BOTTOM_LEFT" style="-fx-background-color: linear-gradient(to top, #0A0A0C 0%, transparent 60%); -fx-padding: 50px;">
            <Label text="TWP" style="-fx-text-fill: #E53935; -fx-font-size: 48px; -fx-font-weight: bold;" />
            <Label text="Sua jornada cinematográfica começa aqui." style="-fx-text-fill: #DDDDDD; -fx-font-size: 18px;" />
        </VBox>
    </StackPane>

    <!-- Right Form -->
    <VBox alignment="CENTER" spacing="25" prefWidth="480" minWidth="400" style="-fx-padding: 60px; -fx-background-color: #0A0A0C;">
        <Label text="Welcome" styleClass="title" style="-fx-font-size: 32px; -fx-text-fill: white; -fx-font-weight: bold;" />
        
        <VBox spacing="8" prefWidth="300" maxWidth="350">
            <Label text="Email address" style="-fx-text-fill: #888;" />
            <TextField fx:id="emailField" promptText="seu@email.com" styleClass="input-field" prefHeight="45" />
        </VBox>
        
        <VBox spacing="8" prefWidth="300" maxWidth="350">
            <Label text="Password" style="-fx-text-fill: #888;" />
            <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="input-field" prefHeight="45" />
        </VBox>
        
        <Label fx:id="statusLabel" textFill="#E53935" wrapText="true" />
        
        <VBox spacing="15" prefWidth="300" maxWidth="350">
            <Button text="Continue with Email" onAction="#handleLogin" styleClass="primary-btn" prefWidth="Infinity" prefHeight="45" />
            <Button text="Create an Account" onAction="#handleRegister" styleClass="secondary-btn" prefWidth="Infinity" prefHeight="45" />
        </VBox>
    </VBox>
</HBox>
